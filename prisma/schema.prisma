// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DepartmentType {
  TRANSPORT // 運搬部署
  PROCESSING // 処理部署
}

enum UserRole {
  ADMIN
  STAFF
}

enum VesselStatus {
  ACTIVE
  DECOMMISSIONED
}

enum TransactionType {
  RECEIVE // 搬入
  PROCESS // 処理
  CALIBRATION // 定期キャリブレーション（実測補正）
  CORRECTION // 過去記録の訂正（逆仕訳）
}

// ログイン用アカウント兼、業務上の作業者（operator）
model User {
  id           String   @id @default(uuid())
  loginId      String   @unique // 会社メールを持たない作業者もいるため、メール形式を強制しない管理者発行のログインID
  passwordHash String
  displayName  String // クレンジング規則：全角半角スペースを完全に除去して保存
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  departmentLinks       OperatorDepartment[]
  recordedTransactions  TankTransaction[]    @relation("RecordedTransactions")
  approvedTransactions  TankTransaction[]    @relation("ApprovedTransactions")
  voidedTransactions    TankTransaction[]    @relation("VoidedTransactions")
  exportRequests        ExportHistory[]
  siteMergeLogs         SiteMergeLog[]

  @@map("users")
}

// 部署マスタ（運搬部署A/B、処理部署C）
model Department {
  id       String         @id @default(uuid())
  name     String
  type     DepartmentType
  isActive Boolean        @default(true)

  operatorLinks OperatorDepartment[]
  siteLinks     SiteDepartment[]
  vesselLinks   VesselDepartment[]
  transactions  TankTransaction[]
  trucks        Truck[]

  @@map("masters_department")
}

// 作業者と部署の多対多（兼任に対応）。入力時に「今回どの部署として作業するか」を選ぶ元データ
model OperatorDepartment {
  id           String   @id @default(uuid())
  userId       String
  departmentId String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@unique([userId, departmentId])
  @@map("operator_department")
}

// 現場マスタ。クレンジング規則：前後の空白のみトリム。
// 一つの現場を複数部署が共用できるよう、所属部署はSiteDepartmentで多対多にしている
model Site {
  id       String  @id @default(uuid())
  name     String  @unique // 同一物理現場は1レコード。自由入力の同時送信による重複登録もDBレベルで根絶
  isActive Boolean @default(true)

  departmentLinks SiteDepartment[]
  shipLinks       SiteShip[]
  transactions    TankTransaction[]

  @@map("masters_site")
}

// 現場と部署の多対多（一現場を複数部署が共用するケースに対応）
model SiteDepartment {
  id           String @id @default(uuid())
  siteId       String
  departmentId String

  site       Site       @relation(fields: [siteId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@unique([siteId, departmentId])
  @@map("site_department")
}

// 本船マスタ（受入元の船）。専用の管理画面（/admin/ships）で登録し、
// 1隻を複数の現場に割り振れる（SiteShip多対多）
model Ship {
  id        String  @id @default(uuid())
  name      String  @unique // 公的書類上の識別性を保つため同名禁止
  imoNumber String? @unique // IMO番号（7桁・任意）。国際的に船舶ごとに一意のため重複禁止
  isActive  Boolean @default(true)

  siteLinks    SiteShip[]
  transactions TankTransaction[]

  @@map("masters_ship")
}

// 現場と本船の多対多（記録画面では「選択された現場に登録されている本船のみ」を表示するための紐付け）
model SiteShip {
  id     String @id @default(uuid())
  siteId String
  shipId String

  site Site @relation(fields: [siteId], references: [id])
  ship Ship @relation(fields: [shipId], references: [id])

  @@unique([siteId, shipId])
  @@map("site_ship")
}

// トラックマスタ（搬入用の陸送車両）。容量・残量管理の対象外の「容器ではない」搬入手段のため、
// バージ/タンクとは別に管理し、部署ごとの選択肢絞り込みのため所属部署を必須とする
model Truck {
  id           String  @id @default(uuid())
  name         String  @unique
  departmentId String
  isActive     Boolean @default(true)

  department   Department        @relation(fields: [departmentId], references: [id])
  transactions TankTransaction[]

  @@map("masters_truck")
}

// 内容物マスタ（ビルジ等）。管理画面からはタンク単位で登録し、ここは内部レジストリとして機能する
// ※台帳の過去データが参照するため、行の物理削除は行わない
model ItemType {
  id       String  @id @default(uuid())
  name     String  @unique // 名前でfindFirst→自動作成するため、レースによる重複をDBレベルで防ぐ
  unit     String  @default("kL")
  isActive Boolean @default(true)

  transactions TankTransaction[]
  vesselLinks  VesselItemType[]

  @@map("masters_item_type")
}

// バージ（船体）マスタ。複数タンクを束ね、残量一覧でグループ集計する
model Barge {
  id               String       @id @default(uuid())
  name             String       @unique // 公的書類の「バージ名／タンク名」表記の識別性を保つため同名禁止
  showTotalOnly    Boolean      @default(false) // 残量一覧でタンクのツリーを出さず、登録タンクの総量のみ表示する
  status           VesselStatus @default(ACTIVE)
  decommissionedAt DateTime?

  vessels Vessel[]

  @@map("masters_barge")
}

// 受入用タンクマスタ。バージに所属させるとバージ残量一覧でグループ表示される
model Vessel {
  id               String       @id @default(uuid())
  name             String
  maxCapacity      Decimal      @db.Decimal(10, 2)
  currentBalance   Decimal      @default(0) @db.Decimal(10, 2) // 最新のtank_transactions.balanceAfterを反映するキャッシュ
  status           VesselStatus @default(ACTIVE)
  decommissionedAt DateTime?
  showIndividually Boolean      @default(true) // バージ配下でツリー行として単一表示するか。falseならバージ合計にのみ含める

  bargeId String?
  barge   Barge?  @relation(fields: [bargeId], references: [id])

  // 所属部署（複数選択可）。リンクが1件もない＝「全部署共通」を意味し、記録画面での絞り込み対象から外れず全部署に表示される
  departmentLinks VesselDepartment[]

  transactions    TankTransaction[]
  allowedContents VesselItemType[]

  // 同一バージ内の同名タンクを禁止（bargeIdがNULL＝所属なし同士はPostgresの仕様上対象外）
  @@unique([bargeId, name])
  @@map("master_vessel")
}

// タンクと部署の多対多（一つのタンクを複数部署が共用できるようにするため）。
// 記録画面での役割はバージ単位ではなく、この「タンク×部署」の組ごとに設定する
// （同じタンクでも部署Aでは受入れのみ、部署Bでは搬入元のみ、といった使い分けに対応するため）
model VesselDepartment {
  id             String  @id @default(uuid())
  vesselId       String
  departmentId   String
  allowReceiving Boolean @default(true) // この部署としてはこのタンクを「受入れタンク」の選択肢に出すか
  allowSourcing  Boolean @default(true) // この部署としてはこのタンクを「搬入タンク（振替元）」の選択肢に出すか

  vessel     Vessel     @relation(fields: [vesselId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@unique([vesselId, departmentId])
  @@map("vessel_department")
}

// タンクに入れられる内容物の登録（記録時はここに登録された内容物のみ選択できる）
model VesselItemType {
  id         String @id @default(uuid())
  vesselId   String
  itemTypeId String

  vessel   Vessel   @relation(fields: [vesselId], references: [id])
  itemType ItemType @relation(fields: [itemTypeId], references: [id])

  @@unique([vesselId, itemTypeId])
  @@map("vessel_item_type")
}

// 追記専用の台帳。搬入・処理・キャリブレーション・訂正のすべてをここに記録する唯一の正データ
model TankTransaction {
  id              String          @id @default(uuid())
  slipId          String // 同一伝票（1回の作業）内の複数品目行をまとめるキー
  businessDate    DateTime        @db.Date // 業務上の対象日（ユーザー入力可）
  createdAt       DateTime        @default(now()) // システムに実際に記録された日時（サーバー側で確定、不変）
  transactionType TransactionType

  vesselId String
  vessel   Vessel @relation(fields: [vesselId], references: [id])

  recordedById String
  recordedBy   User   @relation("RecordedTransactions", fields: [recordedById], references: [id])

  departmentId String? // 記録時に選択した「どの部署としての作業か」。CALIBRATIONでは部署に紐づかないためnull
  department   Department? @relation(fields: [departmentId], references: [id])

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id])

  shipId String? // RECEIVEの場合のみ使用
  ship   Ship?   @relation(fields: [shipId], references: [id])

  truckId String? // RECEIVEでトラック搬入の場合のみ使用（本船と排他ではなく独立した任意選択）
  truck   Truck?  @relation(fields: [truckId], references: [id])

  itemTypeId String? // CALIBRATIONは特定品目に紐づかないためnull
  itemType   ItemType? @relation(fields: [itemTypeId], references: [id])

  quantity     Decimal @db.Decimal(10, 2) // 符号付き（搬入は入力値をそのまま反映＝正が搬入・負が出荷、処理は常に-）
  balanceAfter Decimal @db.Decimal(10, 2) // この行が処理された直後の残高スナップショット

  // CALIBRATION用
  measuredValue      Decimal? @db.Decimal(10, 2) // 実測値
  systemValueBefore  Decimal? @db.Decimal(10, 2) // 補正前のシステム値

  // CORRECTION用：元の行を参照するのみで、元の行は変更・削除しない
  referenceTransactionId String?
  referenceTransaction   TankTransaction?  @relation("TransactionCorrection", fields: [referenceTransactionId], references: [id])
  corrections            TankTransaction[] @relation("TransactionCorrection")

  reason String? // CALIBRATION・CORRECTIONでは必須（アプリ層でバリデーション）

  // 取消（論理削除）。adminのみが伝票単位で設定する。行は物理削除せず、これらの列で「消された」ことを表す。
  // 取消済みの行は出力(CSV)・残量計算・集計から除外し、履歴では横線＋「削除しました」で表示する。
  // DBの追記専用トリガーは、これら取消3列のみのUPDATEを例外的に許可する（siteId訂正と同じ仕組み）
  voidedAt   DateTime? // 取消日時（nullなら有効な記録）
  voidedById String? // 取消を実行した管理者
  voidedBy   User?     @relation("VoidedTransactions", fields: [voidedById], references: [id])
  voidReason String? // 取消理由（取消時は必須・アプリ層でバリデーション）

  approvedById String? // CALIBRATIONは管理者承認必須
  approvedBy   User?   @relation("ApprovedTransactions", fields: [approvedById], references: [id])

  regulatoryTags String[] // 例: ["INDUSTRIAL_WASTE_MANIFEST", "MARINE_POLLUTION_PREVENTION"]

  @@index([vesselId, businessDate])
  @@index([slipId])
  @@map("tank_transactions")
}

// 記録送信の冪等ガード。1回の記録送信＝クライアント生成のUUID1件。
// 連打・通信リトライで同じ送信が二重に届いても、このテーブルへのINSERTが一意制約で弾かれ、
// 台帳への二重記録（誤った連投）を防ぐ。記録トランザクションの先頭でINSERTしてロック兼ガードにする
model RecordSubmission {
  id        String   @id // クライアントが記録フォームごとに発行するUUID
  createdAt DateTime @default(now())

  @@map("record_submissions")
}

// 現場統合の監査ログ。台帳のsiteId訂正（追記専用制約の唯一の例外）の説明責任を担保する。
// 統合元の現場は物理削除されるため、名称・部署は実行時点のスナップショットとして保持する
model SiteMergeLog {
  id                    String   @id @default(uuid())
  executedById          String
  executedBy            User     @relation(fields: [executedById], references: [id])
  departmentNames       String[] // 統合に関わった所属部署名（スナップショット。現場は複数部署に所属し得る）
  targetSiteId          String // 統合先（現存するSiteのid）
  targetSiteName        String // 統合先名称（実行時点のスナップショット）
  sourceSiteNames       String[] // 統合され削除された現場名（スナップショット）
  movedTransactionCount Int // 付け替えた台帳行数
  reason                String // 統合理由（必須）
  createdAt             DateTime @default(now())

  @@map("site_merge_log")
}

// 公的機関提出等のためのエクスポート実行履歴（誰が・いつ・どの範囲を出力したかの証跡）
model ExportHistory {
  id             String   @id @default(uuid())
  requestedById  String
  requestedBy    User     @relation(fields: [requestedById], references: [id])
  periodStart    DateTime @db.Date
  periodEnd      DateTime @db.Date
  filterJson     Json // 対象vessel/department等の絞り込み条件
  format         String // "xlsx" | "pdf" など
  fileHash       String?
  createdAt      DateTime @default(now())

  @@map("export_history")
}
